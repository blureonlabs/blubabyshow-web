# Analytics — PostHog (visitor counts, usage, funnels / drop-off)
# Get these from your PostHog project: Settings → Project → Project API Key.
# Add the same vars in Vercel: Project → Settings → Environment Variables.
# Leave unset locally and analytics simply stays off (no errors).
PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
