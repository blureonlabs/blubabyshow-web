# Analytics — PostHog (visitor counts, usage, funnels / drop-off)
# Get these from your PostHog project: Settings → Project → Project API Key.
# Add the same vars in Vercel: Project → Settings → Environment Variables.
# Leave unset locally and analytics simply stays off (no errors).
PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# SEO — Google Search Console verification (see which queries you rank for,
# submit the sitemap, catch indexing issues). In GSC pick the "HTML tag" method
# and paste ONLY the content token here. Unset = the meta tag is omitted.
PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Lead capture — server-side ONLY (never PUBLIC_*, never commit real values).
# Powers api/subscribe.js: writes signups to the shared Supabase `subscribers`
# table + sends the Resend welcome email. Set all three in Vercel env.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key   # bypasses RLS — keep secret
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx                  # welcome email; unset = welcome skipped

# Rate limiting — OPTIONAL, per-IP abuse protection for /api/subscribe.
# Create a free Upstash Redis DB (upstash.com) → copy its REST URL + token.
# Unset = rate limiting off (signups still work). Fail-open by design.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
