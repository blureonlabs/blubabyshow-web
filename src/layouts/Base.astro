---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Blu Baby Show — Pixar-quality baby comedy for real families',
  description = 'Warm, Pixar-quality stories that teach feelings before they teach facts. 3 new Blu episodes every week. Watched 63M+ times.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/characters/watermark.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/characters/blu.png" />
    <meta property="og:site_name" content="Blu Baby Show" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: Fredoka (head, Bluey-rounded) · Nunito (body) · Newsreader (serif) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito:wght@400;500;600;700;800&family=Newsreader:ital,opsz@0,6..72;1,6..72&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data: brand -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Blu Baby Show',
      url: 'https://blubabyshow.com',
      logo: 'https://blubabyshow.com/characters/watermark.png',
      description: description,
      sameAs: [
        'https://instagram.com/blubabyshow',
        'https://youtube.com/@blubabyshow',
      ],
    })} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
