---
import Base from '../layouts/Base.astro';

/* ------------------------------------------------------------------
   PHASE 0 — the conversion homepage.
   This page doubles as the link-in-bio destination. Its job: take the
   165K/mo profile-visit click and convert it into (a) an owned email
   or (b) a revenue action, above the fold. Everything is ordered by
   monetization leverage, per GROWTH_AND_MONETIZATION.md.
   TODO(studio): swap the static arrays below for Supabase reads
   (published-only) once Blululu ships.
------------------------------------------------------------------ */

const pillars = [
  { title: 'Emotional Mom Moments', blurb: 'Cinematic shorts about the feelings of raising a tiny human.', color: 'var(--coral)' },
  { title: 'Learn with Blu', blurb: 'Numbers, animals, feelings — early learning, Pixar-quality.', color: 'var(--leaf)' },
  { title: 'Blu vs the World', blurb: 'Tiny-chaos comedy. Bubble wrap. Mirrors. Mom’s lipstick.', color: 'var(--honey)' },
  { title: 'Blu’s Family Life', blurb: 'Warm slice-of-life — scooter rides, monsoons, rooftop sunsets.', color: 'var(--lavender)' },
];

// Beacons-replacement quick links — the tappable hub the IG click lands on.
const hubLinks = [
  { label: 'Watch the latest episode', sub: 'New every week', href: 'https://instagram.com/blubabyshow', accent: 'var(--crimson)' },
  { label: 'The Sunday newsletter', sub: 'Free emotion cards inside', href: '#newsletter', accent: 'var(--coral)' },
  { label: 'Blu’s Bedtime music', sub: 'Lullabies on Spotify', href: '#music', accent: 'var(--leaf)' },
  { label: 'The Blu Coloring Book', sub: 'Pre-order · ₹499', href: '#shop', accent: 'var(--honey)' },
  { label: 'Subscribe on YouTube', sub: 'Watch on the big screen', href: 'https://youtube.com/@blubabyshow', accent: 'var(--lavender)' },
];
---

<Base>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap hero__grid">
      <div class="hero__copy">
        <p class="eyebrow">Pixar-quality · new episodes weekly</p>
        <h1>Baby comedy for<br /><span class="hero__accent">real families.</span></h1>
        <p class="hero__sub">
          Warm little stories that teach feelings before they teach facts.
          Three new Blu episodes every week — watched over <strong>63 million</strong> times.
        </p>
        <div class="hero__cta">
          <a class="btn btn--primary" href="https://instagram.com/blubabyshow">▶ Watch Blu</a>
          <a class="btn btn--ghost" href="#newsletter">Get the newsletter</a>
        </div>
        <div class="hero__trust">
          <span><strong>63M+</strong> views</span>
          <span><strong>58K+</strong> family on Instagram</span>
          <span><strong>4</strong> new videos a week</span>
        </div>
      </div>

      <div class="hero__art">
        <div class="hero__blob" aria-hidden="true"></div>
        <img src="/characters/blu.png" alt="Blu, the star of Blu Baby Show" width="520" height="520" fetchpriority="high" />
      </div>
    </div>
  </section>

  <!-- ============ LINK HUB (Beacons replacement) ============ -->
  <section class="hub" aria-label="Quick links">
    <div class="wrap">
      <div class="hub__list">
        {hubLinks.map((l) => (
          <a class="hub__item" href={l.href} style={`--accent:${l.accent}`}>
            <span class="hub__bar" aria-hidden="true"></span>
            <span class="hub__text">
              <span class="hub__label">{l.label}</span>
              <span class="hub__sub">{l.sub}</span>
            </span>
            <span class="hub__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ NEWSLETTER (primary conversion) ============ -->
  <section class="section news" id="newsletter">
    <div class="wrap news__inner">
      <div class="news__copy">
        <p class="eyebrow" style="color:var(--honey)">Small Moments — the newsletter</p>
        <h2>One warm parenting essay + one new Blu video.<br />Every Sunday. Free.</h2>
        <p class="news__lead">
          Read by thousands of parents across India, Brazil and beyond. Subscribe and
          we’ll send you the <strong>free Blu Emotion Cards printable</strong> 📇 to start.
        </p>
        <!-- TODO: point action at Beehiiv embed URL once the account is live -->
        <form class="news__form" action="#" method="post" onsubmit="return false">
          <input class="news__input" type="email" name="email" placeholder="your@email.com" aria-label="Email address" required />
          <button class="btn btn--primary" type="submit">Send me Sunday moments</button>
        </form>
        <p class="news__fine">No spam, ever. One email a week. Unsubscribe anytime.</p>
      </div>
      <div class="news__badge" aria-hidden="true">
        <img src="/characters/blu.png" alt="" width="220" height="220" />
        <span class="news__stamp">Free<br />printable</span>
      </div>
    </div>
  </section>

  <!-- ============ WATCH / PILLARS ============ -->
  <section class="section section--center" id="watch">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">What we make</p>
        <h2>Four kinds of Blu</h2>
        <p class="muted">Every week: one from each. Feelings, learning, laughs, and family.</p>
      </div>
      <div class="pillars">
        {pillars.map((p) => (
          <a class="pill" href="https://instagram.com/blubabyshow" style={`--c:${p.color}`}>
            <span class="pill__swatch" aria-hidden="true"></span>
            <h3>{p.title}</h3>
            <p class="muted">{p.blurb}</p>
            <span class="pill__go">See more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ LEARN ============ -->
  <section class="section section--tint" id="learn">
    <div class="wrap learn__inner">
      <div class="learn__art">
        <img src="/characters/puppy.png" alt="Blu’s puppy" width="360" height="360" />
      </div>
      <div class="learn__copy">
        <p class="eyebrow">Learn with Blu</p>
        <h2>Real early-learning, from a Pixar-quality baby.</h2>
        <p class="muted">
          Numbers, animals, feelings, colors, first words — browsable carousels, free to
          read. Every one ends with a free printable in your inbox.
        </p>
        <a class="btn btn--light" href="#newsletter">Get the free printables →</a>
      </div>
    </div>
  </section>

  <!-- ============ MUSIC (the hidden royalty gold) ============ -->
  <section class="section" id="music">
    <div class="wrap music__inner">
      <div class="music__copy">
        <p class="eyebrow">Blu’s Bedtime</p>
        <h2>Lullabies for winding down.</h2>
        <p class="muted">
          Twinkle Twinkle, Baba Black Sheep and more — Blu’s own bedtime album.
          Press play at 2 a.m. so you don’t have to.
        </p>
        <div class="music__links">
          <a class="btn btn--ghost" href="#">Spotify</a>
          <a class="btn btn--ghost" href="#">Apple Music</a>
          <a class="btn btn--ghost" href="#">YouTube Music</a>
        </div>
      </div>
      <!-- TODO: replace with real Spotify embed iframe once album is distributed via DistroKid -->
      <div class="music__player" aria-hidden="true">
        <div class="music__disc"></div>
        <div class="music__wave">
          <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
        <p>Blu’s Bedtime: Vol. 1 · coming soon</p>
      </div>
    </div>
  </section>

  <!-- ============ SHOP ============ -->
  <section class="section section--tint" id="shop">
    <div class="wrap shop__inner">
      <div class="shop__card">
        <div class="shop__cover">
          <img src="/characters/blu.png" alt="The Blu Coloring Book" width="300" height="300" />
          <span class="shop__ribbon">Pre-order</span>
        </div>
      </div>
      <div class="shop__copy">
        <p class="eyebrow">The Blu shop</p>
        <h2>The Blu Coloring Book</h2>
        <p class="muted">
          32 pages of Blu’s world to color in — feelings, family, and tiny adventures.
          Ships across India and worldwide.
        </p>
        <p class="shop__price">₹499 <span>· ships this season</span></p>
        <!-- TODO: wire to Razorpay Payment Button (India) + Gumroad (global) -->
        <a class="btn btn--primary" href="#">Pre-order the book</a>
      </div>
    </div>
  </section>

  <!-- ============ STORY / ABOUT ============ -->
  <section class="section section--dark section--center" id="story">
    <div class="wrap">
      <div class="section__head" style="margin-inline:auto">
        <p class="eyebrow" style="color:var(--honey)">Blu’s story</p>
        <h2>The world’s first AI-native, Pixar-quality kids brand.</h2>
      </div>
      <p class="story__body">
        Blu is a chubby, curly-haired one-and-a-half-year-old who feels everything
        loudly — and a small studio in Bangalore building a character universe for the
        families the big studios forget. Every episode starts from one true feeling and
        earns its laugh. We think that’s how you build the next Bluey.
      </p>
      <div id="about" class="story__cta">
        <a class="btn btn--light" href="/about">Read the full story</a>
        <a class="btn btn--ghost story__ghost" href="#newsletter">Follow along Sundays</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO ---------- */
  .hero { padding: clamp(2.5rem, 6vw, 4.5rem) 0 clamp(1rem, 3vw, 2rem); overflow: hidden; }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: 2rem;
  }
  .hero__sub { font-size: 1.15rem; max-width: 34ch; color: var(--ink-soft); }
  .hero__accent { color: var(--crimson); }
  .hero__cta { display: flex; gap: 0.8rem; flex-wrap: wrap; margin: 1.8rem 0 1.6rem; }
  .hero__trust {
    display: flex; gap: 1.4rem; flex-wrap: wrap;
    font-size: 0.92rem; color: var(--ink-soft);
  }
  .hero__trust strong { color: var(--ink); font-family: var(--font-head); }
  .hero__art { position: relative; display: grid; place-items: center; }
  .hero__art img { position: relative; z-index: 1; filter: drop-shadow(0 30px 40px rgba(26,24,21,0.22)); }
  .hero__blob {
    position: absolute;
    width: 108%; aspect-ratio: 1;
    background: radial-gradient(circle at 50% 45%, var(--honey), var(--coral) 70%);
    border-radius: 46% 54% 58% 42% / 52% 44% 56% 48%;
    opacity: 0.35;
    filter: blur(4px);
  }

  /* ---------- LINK HUB ---------- */
  .hub { padding-bottom: 1rem; }
  .hub__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
    max-width: 860px;
    margin: 0 auto;
  }
  .hub__item {
    display: flex; align-items: center; gap: 0.9rem;
    background: #fff;
    border-radius: var(--radius-sm);
    padding: 0.95rem 1.1rem;
    box-shadow: var(--shadow-soft);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .hub__item:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
  .hub__bar { width: 5px; align-self: stretch; border-radius: 4px; background: var(--accent); }
  .hub__text { display: flex; flex-direction: column; line-height: 1.25; flex: 1; }
  .hub__label { font-family: var(--font-head); font-weight: 600; }
  .hub__sub { font-size: 0.82rem; color: var(--ink-soft); }
  .hub__arrow { color: var(--accent); font-weight: 700; font-size: 1.15rem; }
  .hub__list > .hub__item:last-child:nth-child(odd) { grid-column: 1 / -1; }

  /* ---------- NEWSLETTER ---------- */
  .news { background: #2f2a22; color: #f6efe0; border-radius: 0; }
  .news__inner {
    display: grid; grid-template-columns: 1.5fr 0.9fr;
    align-items: center; gap: 2rem;
  }
  .news h2 { color: #fff; }
  .news__lead { color: #d8ccb6; max-width: 46ch; }
  .news__form { display: flex; gap: 0.6rem; margin: 1.4rem 0 0.7rem; flex-wrap: wrap; }
  .news__input {
    flex: 1; min-width: 220px;
    padding: 0.85rem 1.1rem;
    border-radius: 999px;
    border: 2px solid rgba(255,255,255,0.16);
    background: rgba(255,255,255,0.06);
    color: #fff; font-size: 1rem; font-family: var(--font-body);
  }
  .news__input::placeholder { color: #b8ab93; }
  .news__input:focus { outline: none; border-color: var(--honey); }
  .news__fine { font-size: 0.8rem; color: #a99a80; margin: 0; }
  .news__badge { position: relative; display: grid; place-items: center; }
  .news__badge img { border-radius: 50%; background: rgba(255,255,255,0.05); }
  .news__stamp {
    position: absolute; right: -6px; bottom: 8px;
    background: var(--crimson); color: #fff;
    font-family: var(--font-head); font-weight: 600; font-size: 0.85rem;
    text-align: center; line-height: 1.05;
    padding: 0.7rem; border-radius: 50%;
    transform: rotate(-8deg);
    box-shadow: var(--shadow);
  }

  /* ---------- PILLARS ---------- */
  .pillars { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }
  .pill {
    background: #fff; border-radius: var(--radius);
    padding: 1.5rem 1.3rem; box-shadow: var(--shadow-soft);
    display: flex; flex-direction: column; gap: 0.3rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    border-top: 4px solid var(--c);
  }
  .pill:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .pill__swatch { width: 40px; height: 40px; border-radius: 12px; background: var(--c); margin-bottom: 0.6rem; }
  .pill h3 { font-size: 1.1rem; }
  .pill p { font-size: 0.9rem; }
  .pill__go { margin-top: auto; font-family: var(--font-head); font-weight: 600; color: var(--crimson); font-size: 0.9rem; }

  /* ---------- LEARN ---------- */
  .learn__inner { display: grid; grid-template-columns: 0.8fr 1.2fr; align-items: center; gap: 2rem; }
  .learn__art img { margin: 0 auto; filter: drop-shadow(0 20px 30px rgba(26,24,21,0.18)); }

  /* ---------- MUSIC ---------- */
  .music__inner { display: grid; grid-template-columns: 1.1fr 0.9fr; align-items: center; gap: 2rem; }
  .music__links { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 1.2rem; }
  .music__player {
    background: #26221c; color: #f6efe0;
    border-radius: var(--radius); padding: 2rem;
    display: grid; place-items: center; gap: 1.2rem; text-align: center;
    box-shadow: var(--shadow);
  }
  .music__disc {
    width: 120px; height: 120px; border-radius: 50%;
    background: conic-gradient(from 0deg, #3a352c, #26221c, #3a352c);
    border: 6px solid #1a1712;
    position: relative;
  }
  .music__disc::after {
    content: ''; position: absolute; inset: 46%;
    background: var(--crimson); border-radius: 50%;
  }
  .music__wave { display: flex; align-items: flex-end; gap: 5px; height: 34px; }
  .music__wave span {
    width: 5px; background: var(--honey); border-radius: 3px;
    animation: eq 1.1s ease-in-out infinite;
  }
  .music__wave span:nth-child(1) { height: 40%; animation-delay: 0s; }
  .music__wave span:nth-child(2) { height: 80%; animation-delay: 0.1s; }
  .music__wave span:nth-child(3) { height: 55%; animation-delay: 0.2s; }
  .music__wave span:nth-child(4) { height: 100%; animation-delay: 0.3s; }
  .music__wave span:nth-child(5) { height: 60%; animation-delay: 0.15s; }
  .music__wave span:nth-child(6) { height: 85%; animation-delay: 0.25s; }
  .music__wave span:nth-child(7) { height: 45%; animation-delay: 0.05s; }
  @keyframes eq { 0%, 100% { transform: scaleY(0.5); } 50% { transform: scaleY(1); } }
  .music__player p { margin: 0; font-size: 0.9rem; color: #b8ab93; }

  /* ---------- SHOP ---------- */
  .shop__inner { display: grid; grid-template-columns: 0.9fr 1.1fr; align-items: center; gap: 2rem; }
  .shop__cover {
    position: relative; background: #fff; border-radius: var(--radius);
    padding: 2rem; box-shadow: var(--shadow); display: grid; place-items: center;
    max-width: 340px; margin: 0 auto;
  }
  .shop__cover img { border-radius: var(--radius-sm); }
  .shop__ribbon {
    position: absolute; top: 16px; left: -6px;
    background: var(--crimson); color: #fff;
    font-family: var(--font-head); font-weight: 600; font-size: 0.8rem;
    padding: 0.35rem 0.9rem; border-radius: 4px;
    box-shadow: var(--shadow-soft);
  }
  .shop__price {
    font-family: var(--font-head); font-weight: 700;
    font-size: 1.8rem; color: var(--crimson); margin: 0.4rem 0 1.2rem;
  }
  .shop__price span { font-size: 0.95rem; font-weight: 500; color: var(--ink-soft); }

  /* ---------- STORY ---------- */
  .story__body {
    font-family: var(--font-serif); font-size: 1.3rem; line-height: 1.6;
    max-width: 56ch; margin: 0 auto 2rem; text-align: center; color: #e8ddc9;
  }
  .story__cta { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; }
  .story__ghost { color: #f6efe0; border-color: rgba(255,255,255,0.25); }
  .story__ghost:hover { border-color: #fff; }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px) {
    .hero__grid, .news__inner, .learn__inner, .music__inner, .shop__inner { grid-template-columns: 1fr; }
    .hero__art { order: -1; max-width: 380px; margin: 0 auto; }
    .news__badge { display: none; }
    .pillars { grid-template-columns: repeat(2, 1fr); }
    .learn__art { display: none; }
  }
  @media (max-width: 560px) {
    .hub__list { grid-template-columns: 1fr; }
    .pillars { grid-template-columns: 1fr; }
    .hero__cta .btn { flex: 1; }
  }
</style>
