---
import Base from '../layouts/Base.astro';
import Doodles from '../components/Doodles.astro';
import Icon from '../components/Icon.astro';

/* ------------------------------------------------------------------
   PHASE 0 — "Blu's Sunny World" homepage.
   Bluey-warm × Cocomelon-catchy. Character-first, bright, joyful.
   Doubles as the link-in-bio destination: convert the 165K/mo IG
   profile-visit click into an owned email or a revenue action.
   Swap the placeholder character PNGs (same filenames) as better
   art is generated. TODO(studio): read published content from Supabase.
------------------------------------------------------------------ */

const pillars = [
  { title: 'Big Feelings', blurb: 'Cinematic little moments about the feelings of raising a tiny human.', c: 'var(--orange)', icon: 'heart' },
  { title: 'Learn with Blu', blurb: 'Numbers, animals, feelings — early learning, Pixar-quality.', c: 'var(--grass)', icon: 'book' },
  { title: 'Blu vs the World', blurb: 'Tiny-chaos comedy. Bubble wrap. Mirrors. Mum’s lipstick.', c: 'var(--sun)', icon: 'smile' },
  { title: 'Family Life', blurb: 'Warm slice-of-life — scooter rides, monsoons, rooftop sunsets.', c: 'var(--grape)', icon: 'home' },
];

const hub = [
  { label: 'Watch the newest episode', sub: 'New every week', href: 'https://instagram.com/theblubabyshow', c: 'var(--blu)', icon: 'play' },
  { label: 'Join Blu’s Sunday Club', sub: 'Free emotion cards inside', href: '#newsletter', c: 'var(--sun)', icon: 'mail' },
  { label: 'Blu’s Bedtime music', sub: 'Lullabies on Spotify', href: '#music', c: 'var(--grape)', icon: 'music' },
  { label: 'The Blu Colouring Book', sub: 'Pre-order · ₹499', href: '#shop', c: 'var(--grass)', icon: 'pencil' },
  { label: 'Watch on the big screen', sub: 'Subscribe on YouTube', href: 'https://youtube.com/@blubabyshow', c: 'var(--sky)', icon: 'tv' },
];

const family = [
  { img: '/characters/blu.png',    name: 'Blu',    tag: 'the star', c: 'var(--blu)' },
  { img: '/characters/mom.png',    name: 'Mum',    tag: 'tired & tender', c: 'var(--pink)' },
  { img: '/characters/dad.png',    name: 'Dad',    tag: 'shows up', c: 'var(--sky)' },
  { img: '/characters/puppy.png',  name: 'Puppy',  tag: 'the sidekick', c: 'var(--sun)' },
  { img: '/characters/sister.png', name: 'Sister', tag: 'the ringleader', c: 'var(--grape)' },
];
---

<Base>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <span class="hero__sun" aria-hidden="true"></span>
    <span class="hero__cloud c-a" aria-hidden="true"></span>
    <span class="hero__cloud c-b" aria-hidden="true"></span>
    <span class="hero__cloud c-c" aria-hidden="true"></span>
    <Doodles variant="hero" />

    <div class="wrap hero__grid">
      <div class="hero__copy">
        <span class="badge reveal d1"><Icon name="sparkle" size={16} class="badge__ic" /> Pixar-quality · new episodes weekly</span>
        <h1 class="reveal d2">The happiest<br /><span class="hero__pop">little show</span><br />for real families.</h1>
        <p class="hero__sub reveal d3">
          Warm, giggly stories that teach feelings before they teach facts.
          Watched over <strong>63 million</strong> times by families around the world.
        </p>
        <div class="hero__cta reveal d4">
          <a class="btn btn--primary" href="https://instagram.com/theblubabyshow">▶ Watch Blu</a>
          <a class="btn btn--sun" href="#newsletter">Join the club — it’s free</a>
        </div>
        <div class="hero__stats reveal d5">
          <span><b>63M+</b> views</span>
          <span class="dotsep">·</span>
          <span><b>58K+</b> families</span>
          <span class="dotsep">·</span>
          <span><b>4</b> new a week</span>
        </div>
      </div>

      <div class="hero__stage">
        <span class="hero__ring" aria-hidden="true"></span>
        <img class="hero__blu" src="/characters/blu.png" alt="Blu, the star of Blu Baby Show" width="470" height="640" fetchpriority="high" />
        <img class="hero__peek hero__peek--puppy sticker" src="/characters/puppy.png" alt="" width="180" height="180" aria-hidden="true" />
        <span class="hero__chip chip-1"><Icon name="sparkle" size={15} /> giggles</span>
        <span class="hero__chip chip-2"><Icon name="heart" size={15} /> feelings</span>
      </div>
    </div>

    <!-- grassy hill divider into the page -->
    <svg class="hero__hill" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 110 480 20 720 50 C 960 80 1200 110 1440 55 L1440 120 L0 120 Z" fill="var(--grass)"/>
      <path d="M0 78 C 240 120 480 44 720 70 C 960 96 1200 120 1440 74 L1440 120 L0 120 Z" fill="var(--grass-d)" opacity="0.65"/>
    </svg>
  </section>

  <!-- ============ STATS MARQUEE ============ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {Array.from({ length: 2 }).map(() => (
        <span class="marquee__row">
          <b>63M+ views</b> ★ <b>58K+ families</b> ★ <b>3 countries in the top 5</b> ★
          <b>4 new episodes a week</b> ★ <b>feelings before facts</b> ★
        </span>
      ))}
    </div>
  </div>

  <!-- ============ LINK HUB ============ -->
  <section class="section hub-sec">
    <div class="wrap">
      <div class="section__head section--center">
        <p class="eyebrow">Start here</p>
        <h2>Where do you want to go?</h2>
      </div>
      <div class="hub">
        {hub.map((l, i) => (
          <a class={`hub__card tilt${i % 2}`} href={l.href} style={`--c:${l.c}`}>
            <span class="hub__ic"><Icon name={l.icon} size={22} /></span>
            <span class="hub__t">
              <span class="hub__label">{l.label}</span>
              <span class="hub__sub">{l.sub}</span>
            </span>
            <span class="hub__arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ NEWSLETTER (primary conversion) ============ -->
  <section class="section news" id="newsletter">
    <Doodles variant="sparse" />
    <div class="wrap news__card">
      <div class="news__copy">
        <p class="eyebrow eyebrow--light"><Icon name="mail" size={16} /> Blu’s Sunday Club</p>
        <h2>One warm story + one new Blu video.<br />Every Sunday. Free.</h2>
        <p class="news__lead">
          Join thousands of parents across India, Brazil &amp; beyond. Subscribe and we’ll
          send you the <strong>free Blu Emotion Cards</strong> printable to start.
        </p>
        <!-- TODO: point action at Beehiiv embed URL once the account is live -->
        <form class="news__form" action="#" method="post" onsubmit="return false">
          <input class="news__input" type="email" name="email" placeholder="your@email.com" aria-label="Email address" required />
          <button class="btn btn--sun" type="submit">Send me Sunday moments</button>
        </form>
        <p class="news__fine">No spam, ever · one email a week · unsubscribe anytime</p>
      </div>
      <div class="news__art" aria-hidden="true">
        <img class="sticker" src="/characters/mom.png" alt="" width="240" height="240" />
        <span class="news__stamp">FREE<br />printable</span>
      </div>
    </div>
  </section>

  <!-- ============ PILLARS ============ -->
  <section class="section section--center" id="watch">
    <div class="wrap">
      <div class="section__head">
        <p class="eyebrow">What we make</p>
        <h2>Four kinds of Blu</h2>
        <p class="muted">Every week: one from each. Feelings, learning, laughs and family.</p>
      </div>
      <div class="pillars">
        {pillars.map((p, i) => (
          <a class={`pill tilt${i % 2}`} href="https://instagram.com/theblubabyshow" style={`--c:${p.c}`}>
            <span class="pill__emoji"><Icon name={p.icon} size={26} /></span>
            <h3>{p.title}</h3>
            <p class="muted">{p.blurb}</p>
            <span class="pill__go">See more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ MEET THE FAMILY ============ -->
  <section class="section fam" id="story">
    <div class="wrap">
      <div class="section__head section--center">
        <p class="eyebrow" style="color:#fff">The whole gang</p>
        <h2 style="color:#fff">Meet Blu’s family</h2>
      </div>
      <div class="fam__row">
        {family.map((m) => (
          <div class="fam__card" style={`--c:${m.c}`}>
            <div class="fam__ph"><img src={m.img} alt={m.name} width="150" height="150" /></div>
            <strong>{m.name}</strong>
            <span>{m.tag}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ LEARN ============ -->
  <section class="section learn" id="learn">
    <div class="wrap learn__grid">
      <div class="learn__art">
        <span class="learn__blob" aria-hidden="true"></span>
        <img class="sticker" src="/characters/puppy.png" alt="Blu’s puppy learning with blocks" width="340" height="340" />
      </div>
      <div class="learn__copy">
        <p class="eyebrow">Learn with Blu</p>
        <h2>Real early-learning, from a Pixar-quality baby.</h2>
        <p class="muted">
          Numbers, animals, feelings, colours, first words — browsable, free to read.
          Every carousel ends with a free printable dropped straight to your inbox.
        </p>
        <a class="btn btn--grass" href="#newsletter">Get the free printables →</a>
      </div>
    </div>
  </section>

  <!-- ============ MUSIC ============ -->
  <section class="section music" id="music">
    <div class="wrap music__grid">
      <div class="music__copy">
        <p class="eyebrow">Blu’s Bedtime</p>
        <h2>Lullabies for winding down.</h2>
        <p class="muted">
          Twinkle Twinkle, Baba Black Sheep &amp; more — Blu’s own bedtime album.
          Press play at 2 a.m. so you don’t have to sing it yourself.
        </p>
        <div class="music__links">
          <a class="btn btn--ghost" href="#">Spotify</a>
          <a class="btn btn--ghost" href="#">Apple Music</a>
          <a class="btn btn--ghost" href="#">YouTube Music</a>
        </div>
      </div>
      <!-- TODO: replace with real Spotify embed once distributed via DistroKid -->
      <div class="player">
        <div class="player__disc"><span></span></div>
        <div class="player__wave">
          {Array.from({ length: 9 }).map(() => <span></span>)}
        </div>
        <p>Blu’s Bedtime: Vol. 1 · coming soon</p>
      </div>
    </div>
  </section>

  <!-- ============ SHOP ============ -->
  <section class="section shop" id="shop">
    <div class="wrap shop__grid">
      <div class="shop__cover">
        <span class="shop__ribbon">Pre-order</span>
        <img class="sticker" src="/characters/blu_book.png" alt="Blu holding the Blu Colouring Book" width="300" height="300" />
      </div>
      <div class="shop__copy">
        <p class="eyebrow">The Blu Shop</p>
        <h2>The Blu Colouring Book</h2>
        <p class="muted">
          32 pages of Blu’s world to colour in — feelings, family and tiny adventures.
          Ships across India and worldwide.
        </p>
        <p class="shop__price">₹499 <span>· ships this season</span></p>
        <!-- TODO: wire to Razorpay Payment Button (India) + Gumroad (global) -->
        <a class="btn btn--primary" href="#">Pre-order the book</a>
      </div>
    </div>
  </section>

  <!-- ============ CLOSING CTA ============ -->
  <section class="section closing section--center">
    <Doodles variant="hero" />
    <div class="wrap">
      <img class="closing__blu" src="/characters/blu.png" alt="" width="150" height="150" aria-hidden="true" />
      <h2>Come hang out with Blu every week.</h2>
      <p class="muted closing__sub">Free. Warm. Three new little episodes, every single week.</p>
      <div class="closing__cta">
        <a class="btn btn--primary" href="https://instagram.com/theblubabyshow">Follow on Instagram</a>
        <a class="btn btn--sun" href="#newsletter">Join Blu’s Sunday Club</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    padding: clamp(2rem, 5vw, 3.5rem) 0 5.5rem;
    background:
      radial-gradient(120% 90% at 82% 6%, #fff6d6 0%, rgba(255,246,214,0) 42%),
      linear-gradient(180deg, var(--sky) 0%, #b7e0fd 46%, #d6ecff 100%);
    overflow: hidden;
  }
  .hero__sun {
    position: absolute; top: -70px; right: -60px; width: 320px; height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--sun) 0%, #ffd98a 55%, rgba(255,217,138,0) 72%);
    animation: spinSlow 60s linear infinite; opacity: 0.9;
  }
  .hero__cloud {
    position: absolute; border-radius: 999px; background: #fff;
    box-shadow: 40px 8px 0 -6px #fff, -38px 10px 0 -8px #fff;
    opacity: 0.9;
  }
  .hero__cloud.c-a { top: 14%; width: 90px; height: 34px; left: -10%; animation: drift 38s linear infinite; }
  .hero__cloud.c-b { top: 30%; width: 70px; height: 26px; left: -10%; animation: drift 52s linear infinite 6s; }
  .hero__cloud.c-c { top: 8%;  width: 60px; height: 22px; left: -10%; animation: drift 46s linear infinite 14s; }

  .hero__grid {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1.05fr 0.95fr;
    align-items: center; gap: 2rem;
  }
  .hero__pop {
    color: var(--orange);
    -webkit-text-stroke: 0;
    position: relative; display: inline-block;
  }
  .hero__pop::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: 4px; height: 12px;
    background: var(--sun); border-radius: 8px; z-index: -1; transform: rotate(-1deg);
  }
  .hero__sub { font-size: 1.2rem; max-width: 36ch; color: var(--ink-soft); margin-top: 0.4rem; }
  .hero__cta { display: flex; gap: 0.9rem; flex-wrap: wrap; margin: 1.9rem 0 1.5rem; }
  .hero__stats { display: flex; align-items: center; gap: 0.8rem; color: var(--ink-soft); font-size: 0.98rem; }
  .hero__stats b { font-family: var(--font-head); color: var(--ink); }
  .dotsep { color: var(--sun-d); }

  .hero__stage { position: relative; display: grid; place-items: center; min-height: 460px; }
  .hero__ring {
    position: absolute; width: 98%; aspect-ratio: 1; border-radius: 50%;
    background: radial-gradient(circle at 50% 52%, #ffffff 0%, rgba(255,255,255,0.55) 42%, rgba(255,255,255,0) 70%);
    opacity: 0.85;
  }
  .hero__blu { position: relative; z-index: 2; animation: popIn 0.7s cubic-bezier(.34,1.56,.64,1) both, float 5.5s ease-in-out infinite 0.8s; }
  .hero__peek--puppy {
    position: absolute; z-index: 3; bottom: 6%; right: 4%;
    width: 170px; animation: bob 4.5s ease-in-out infinite;
  }
  .hero__chip {
    position: absolute; z-index: 4;
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-family: var(--font-head); font-weight: 600; font-size: 0.9rem;
    background: #fff; padding: 0.45rem 0.9rem; border-radius: 999px;
    box-shadow: var(--shadow-sticker);
  }
  .chip-1 { top: 14%; left: -2%; color: var(--grape-d); animation: floatSm 4s ease-in-out infinite; }
  .chip-2 { bottom: 20%; left: 2%; color: var(--orange-d); animation: floatSm 5s ease-in-out infinite 0.6s; }

  .hero__hill { position: absolute; left: 0; right: 0; bottom: -1px; width: 100%; height: 90px; z-index: 1; }

  /* ---------- MARQUEE ---------- */
  .marquee {
    background: var(--blu-deep); color: #fff; overflow: hidden;
    padding: 0.7rem 0; border-top: 4px solid rgba(255,255,255,0.15);
  }
  .marquee__track { display: flex; width: max-content; animation: marquee 26s linear infinite; }
  .marquee__row {
    font-family: var(--font-head); font-weight: 600; font-size: 1.05rem;
    white-space: nowrap; padding-right: 1rem; display: inline-flex; gap: 0.6rem;
  }
  .marquee__row b { font-weight: 600; }

  /* ---------- HUB ---------- */
  .hub-sec { background: var(--cream); }
  .hub { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.3rem; max-width: 940px; margin: 0 auto; }
  .hub__card {
    display: flex; align-items: center; gap: 1.1rem;
    background: var(--c); color: #fff; border-radius: var(--radius);
    padding: 1.5rem 1.6rem;
    border: 3px solid #fff;
    box-shadow: 0 10px 0 -1px color-mix(in srgb, var(--c), #000 24%), var(--shadow-soft);
    transition: transform 0.16s cubic-bezier(.34,1.56,.64,1), box-shadow 0.16s ease;
  }
  .hub__card:hover { transform: translateY(-5px) rotate(-1deg); box-shadow: 0 14px 0 -1px color-mix(in srgb, var(--c), #000 24%), var(--shadow); }
  .hub__ic {
    flex: none; width: 54px; height: 54px; border-radius: 16px;
    background: rgba(255,255,255,0.92); color: var(--c); display: grid; place-items: center;
    box-shadow: inset 0 -4px 0 rgba(0,0,0,0.08);
  }
  .hub__t { display: flex; flex-direction: column; line-height: 1.25; flex: 1; }
  .hub__label { font-family: var(--font-head); font-weight: 700; font-size: 1.1rem; }
  .hub__sub { font-size: 0.86rem; color: rgba(255,255,255,0.85); }
  .hub__arrow { font-family: var(--font-head); font-weight: 700; font-size: 1.4rem; color: #fff; }
  .hub__card:last-child:nth-child(odd) { grid-column: 1 / -1; }

  .tilt0 { transform: rotate(-0.6deg); }
  .tilt1 { transform: rotate(0.6deg); }
  .tilt0:hover, .tilt1:hover { transform: translateY(-4px) rotate(0); }

  /* ---------- NEWSLETTER ---------- */
  .news { position: relative; background: var(--cream); }
  .news__card {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1.5fr 0.8fr; align-items: center; gap: 2rem;
    background: linear-gradient(135deg, var(--orange) 0%, var(--orange-d) 100%);
    color: #fff; border-radius: var(--radius); padding: clamp(2rem, 4vw, 3.2rem);
    box-shadow: var(--shadow); overflow: hidden;
  }
  .news h2 { color: #fff; }
  .news__lead { color: rgba(255,255,255,0.9); max-width: 46ch; }
  .news__form { display: flex; gap: 0.6rem; margin: 1.4rem 0 0.7rem; flex-wrap: wrap; }
  .news__input {
    flex: 1; min-width: 220px; padding: 0.9rem 1.2rem; border-radius: 999px;
    border: 0; background: rgba(255,255,255,0.95); color: var(--ink);
    font-size: 1rem; font-family: var(--font-body);
  }
  .news__input:focus { outline: 3px solid var(--sun); }
  .news__fine { font-size: 0.8rem; color: rgba(255,255,255,0.75); margin: 0; }
  .news__art { position: relative; display: grid; place-items: center; }
  .news__art img { width: 240px; height: 240px; border-radius: 50%; background: rgba(255,255,255,0.16); object-fit: cover; object-position: 50% 14%; }
  .news__stamp {
    position: absolute; right: -4px; bottom: 6px;
    background: var(--sun); color: #5a3d00;
    font-family: var(--font-head); font-weight: 700; font-size: 0.8rem; text-align: center;
    line-height: 1.05; padding: 0.7rem; border-radius: 50%;
    transform: rotate(-10deg); box-shadow: var(--shadow-sticker);
  }

  /* ---------- PILLARS ---------- */
  .pillars { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.1rem; }
  .pill {
    background: #fff; border-radius: var(--radius); padding: 1.6rem 1.35rem;
    box-shadow: var(--shadow-soft); border-bottom: 6px solid var(--c);
    display: flex; flex-direction: column; gap: 0.3rem; text-align: left;
    transition: transform 0.16s cubic-bezier(.34,1.56,.64,1), box-shadow 0.16s ease;
  }
  .pill:hover { transform: translateY(-6px) rotate(0); box-shadow: var(--shadow); }
  .pill__emoji {
    width: 56px; height: 56px; border-radius: 16px; background: color-mix(in srgb, var(--c) 20%, #fff);
    display: grid; place-items: center; margin-bottom: 0.7rem;
    color: color-mix(in srgb, var(--c), var(--ink) 35%);
  }
  .pill h3 { font-size: 1.15rem; }
  .pill p { font-size: 0.9rem; }
  .pill__go { margin-top: auto; font-family: var(--font-head); font-weight: 600; color: var(--ink); font-size: 0.92rem; }

  /* ---------- MEET THE FAMILY ---------- */
  .fam { background: linear-gradient(180deg, var(--blu) 0%, var(--blu-deep) 100%); }
  .fam__row { display: flex; justify-content: center; gap: 1.2rem; flex-wrap: wrap; }
  .fam__card {
    background: #fff; border-radius: var(--radius); padding: 1.2rem 1rem 1.4rem;
    width: 160px; text-align: center; box-shadow: var(--shadow-soft);
    transition: transform 0.18s ease;
  }
  .fam__card:hover { transform: translateY(-6px) rotate(-2deg); }
  .fam__card strong { display: block; font-family: var(--font-head); font-size: 1.15rem; margin-top: 0.6rem; }
  .fam__card span { font-size: 0.82rem; color: var(--ink-soft); }
  .fam__ph {
    width: 120px; height: 120px; margin: 0 auto; border-radius: 50%;
    background: color-mix(in srgb, var(--c) 22%, #fff);
    display: grid; place-items: center; overflow: hidden;
  }
  .fam__ph img { width: 108px; height: 108px; object-fit: contain; }

  /* ---------- LEARN ---------- */
  .learn { background: var(--sand); }
  .learn__grid { display: grid; grid-template-columns: 0.85fr 1.15fr; align-items: center; gap: 2.5rem; }
  .learn__art { position: relative; display: grid; place-items: center; }
  .learn__blob {
    position: absolute; width: 82%; aspect-ratio: 1;
    background: radial-gradient(circle, var(--grass) 0%, #b6e6b3 60%, rgba(182,230,179,0) 72%);
    border-radius: 46% 54% 58% 42% / 52% 44% 56% 48%; opacity: 0.5;
  }
  .learn__art img { position: relative; z-index: 1; animation: floatSm 5s ease-in-out infinite; }

  /* ---------- MUSIC ---------- */
  .music { background: linear-gradient(180deg, #2b2545 0%, #1f1b36 100%); color: #f4efff; }
  .music .muted { color: #c4bce0; }
  .music__grid { display: grid; grid-template-columns: 1.1fr 0.9fr; align-items: center; gap: 2.5rem; }
  .music h2 { color: #fff; }
  .music__links { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 1.2rem; }
  .music__links .btn--ghost { background: rgba(255,255,255,0.1); color: #fff; box-shadow: none; }
  .player {
    background: rgba(255,255,255,0.06); border-radius: var(--radius); padding: 2.2rem;
    display: grid; place-items: center; gap: 1.3rem; text-align: center;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .player__disc {
    width: 130px; height: 130px; border-radius: 50%;
    background: conic-gradient(from 0deg, #3a3358, #241f3d, #3a3358);
    border: 7px solid #14101f; display: grid; place-items: center;
