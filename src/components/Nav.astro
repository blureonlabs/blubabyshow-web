---
// Launch nav — 5 decisive doors. Press + For Brands live in the footer.
// On the Phase-0 single page these are anchor links; they become real
// routes in Phase 1. Mobile: pure-CSS checkbox toggle + inline JS to
// close the panel after a link tap.
const links = [
  { label: 'Watch', href: '#watch' },
  { label: 'Learn', href: '#learn' },
  { label: 'Shop', href: '#shop' },
  { label: 'Story', href: '#story' },
  { label: 'Newsletter', href: '#newsletter' },
];
---

<header class="nav">
  <div class="wrap nav__inner">
    <a class="nav__brand" href="/">
      <span class="nav__mark" aria-hidden="true"></span>
      <span class="nav__word">Blu&nbsp;Baby&nbsp;Show</span>
    </a>

    <input type="checkbox" id="navtoggle" class="nav__toggle" hidden />
    <label for="navtoggle" class="nav__burger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav__menu" aria-label="Primary">
      <div class="nav__links">
        {links.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
      <a class="btn btn--primary nav__cta" href="#newsletter">Get the newsletter</a>
    </nav>
  </div>
</header>

<script is:inline>
  // Close the mobile panel after tapping a link.
  document.querySelectorAll('.nav__menu a').forEach((a) =>
    a.addEventListener('click', () => {
      const t = document.getElementById('navtoggle');
      if (t) t.checked = false;
    })
  );
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid rgba(48, 89, 138, 0.1);
    box-shadow: 0 4px 22px -14px rgba(43, 44, 65, 0.3);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 74px;
    gap: 1.25rem;
  }

  /* ---- Brand ---- */
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.32rem;
    color: var(--blu-deep);
    white-space: nowrap;
  }
  .nav__mark {
    position: relative;
    flex: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 28%, #a7d7fc, var(--blu) 52%, var(--blu-deep));
    box-shadow:
      0 0 0 4px rgba(87, 176, 240, 0.18),
      inset 0 -3px 5px rgba(0, 0, 0, 0.14),
      inset 0 3px 6px rgba(255, 255, 255, 0.55);
  }
  .nav__mark::after {
    content: "";
    position: absolute;
    top: 8px;
    left: 9px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
  }

  /* ---- Menu (desktop) ---- */
  .nav__menu { display: flex; align-items: center; gap: 1.8rem; }
  .nav__links {
    display: flex;
    gap: 0.25rem;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1rem;
  }
  .nav__links a {
    color: var(--ink);
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav__links a:hover { background: var(--cream-2); color: var(--blu-d); }
  .nav__cta { padding: 0.6rem 1.25rem; font-size: 0.98rem; }

  /* ---- Burger (hidden on desktop) ---- */
  .nav__burger { display: none; }

  /* ---- Mobile ---- */
  @media (max-width: 860px) {
    .nav__burger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 46px;
      height: 46px;
      border-radius: 14px;
      background: var(--cream-2);
      cursor: pointer;
      flex: none;
      -webkit-tap-highlight-color: transparent;
    }
    .nav__burger span {
      display: block;
      width: 22px;
      height: 3px;
      margin: 0 auto;
      border-radius: 3px;
      background: var(--blu-deep);
      transition: transform 0.22s ease, opacity 0.18s ease;
    }

    .nav__menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      background: #fff;
      padding: 0.9rem 1.4rem 1.4rem;
      border-bottom: 1px solid rgba(48, 89, 138, 0.1);
      box-shadow: 0 22px 34px -20px rgba(43, 44, 65, 0.35);
      transform: translateY(-14px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.22s ease, opacity 0.22s ease;
    }
    .nav__toggle:checked ~ .nav__menu {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    .nav__links { flex-direction: column; gap: 0.15rem; font-size: 1.12rem; }
    .nav__links a { padding: 0.7rem 0.9rem; }
    .nav__cta { width: 100%; margin-top: 0.4rem; }

    /* burger → X */
    .nav__toggle:checked ~ .nav__burger span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
    .nav__toggle:checked ~ .nav__burger span:nth-child(2) { opacity: 0; }
    .nav__toggle:checked ~ .nav__burger span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
  }

  @media (max-width: 420px) {
    .nav__inner { height: 66px; }
    .nav__word { font-size: 1.15rem; }
    .nav__mark { width: 32px; height: 32px; }
  }
</style>
