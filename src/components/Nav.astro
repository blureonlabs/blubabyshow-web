---
// Launch nav — 5 decisive doors. bluey.tv-style: logo left; on mobile a
// navy mail circle + hamburger circle on the right. Pure-CSS checkbox toggle
// + inline JS to close the panel after a link tap.
const links = [
  { label: 'Watch', href: '#watch' },
  { label: 'Learn', href: '#learn' },
  { label: 'Shop', href: '#shop' },
  { label: 'Story', href: '#story' },
  { label: 'Newsletter', href: '#newsletter' },
];
---

<header class="nav">
  <div class="wrap nav__inner">
    <a class="nav__brand" href="/">
      <img class="nav__mark" src="/characters/watermark.png" alt="" width="38" height="38" aria-hidden="true" />
      <span class="nav__word">Blu&nbsp;Baby&nbsp;Show</span>
    </a>

    <input type="checkbox" id="navtoggle" class="nav__toggle" hidden />

    <nav class="nav__menu" aria-label="Primary">
      <div class="nav__links">
        {links.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
      <a class="btn btn--primary nav__cta" href="#newsletter">Get the newsletter</a>
    </nav>

    <div class="nav__actions">
      <a class="nav__circle" href="#newsletter" aria-label="Get the newsletter">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
      <label class="nav__circle nav__burger" for="navtoggle" aria-label="Open menu">
        <span></span><span></span><span></span>
      </label>
    </div>
  </div>
</header>

<script is:inline>
  // Close the mobile panel after tapping a link.
  document.querySelectorAll('.nav__menu a').forEach((a) =>
    a.addEventListener('click', () => {
      const t = document.getElementById('navtoggle');
      if (t) t.checked = false;
    })
  );
</script>

<style>
  /* Floating "island" nav — a rounded pill detached from the edges */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 0.8rem 16px 0;
    background: transparent;
  }
  .nav__inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    width: 100%;
    max-width: 1060px;
    margin: 0 auto;
    height: 64px;
    padding: 0 0.5rem 0 1.15rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: saturate(180%) blur(14px);
    box-shadow: 0 14px 34px -14px rgba(43, 44, 65, 0.32), 0 2px 8px -2px rgba(43, 44, 65, 0.08);
    border: 1.5px solid rgba(255, 255, 255, 0.7);
  }

  /* ---- Brand ---- */
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.32rem;
    color: var(--blu-deep);
    white-space: nowrap;
  }
  .nav__word { overflow: hidden; text-overflow: ellipsis; }
  .nav__actions { flex: none; }
  .nav__mark {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: 11px;
    display: block;
    filter: drop-shadow(0 4px 8px rgba(43, 44, 65, 0.22));
  }

  /* ---- Menu (desktop) ---- */
  .nav__menu { display: flex; align-items: center; gap: 1.8rem; }
  .nav__links {
    display: flex;
    gap: 0.25rem;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1rem;
  }
  .nav__links a {
    color: var(--ink);
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav__links a:hover { background: var(--cream-2); color: var(--blu-d); }
  .nav__cta { padding: 0.6rem 1.25rem; font-size: 0.98rem; }

  /* ---- Circular action buttons (mobile only) ---- */
  .nav__actions { display: none; align-items: center; gap: 0.6rem; }
  .nav__circle {
    flex: none;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--blu-deep);
    color: #fff;
    cursor: pointer;
    box-shadow: 0 6px 14px -6px rgba(43, 44, 65, 0.4);
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.15s ease;
  }
  .nav__circle:hover { transform: translateY(-2px); }
  .nav__burger { flex-direction: column; gap: 5px; }
  .nav__burger span {
    display: block;
    width: 20px;
    height: 2.5px;
    border-radius: 3px;
    background: #fff;
    transition: transform 0.22s ease, opacity 0.18s ease;
  }

  /* ---- Mobile ---- */
  @media (max-width: 860px) {
    .nav__actions { display: flex; }

    .nav__menu {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      background: #fff;
      padding: 1rem 1.1rem 1.2rem;
      border-radius: 26px;
      border: 1.5px solid rgba(255, 255, 255, 0.7);
      box-shadow: 0 24px 44px -18px rgba(43, 44, 65, 0.4);
      transform: translateY(-14px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.22s ease, opacity 0.22s ease;
    }
    .nav__toggle:checked ~ .nav__menu {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    .nav__links { flex-direction: column; gap: 0.15rem; font-size: 1.12rem; }
    .nav__links a { padding: 0.7rem 0.9rem; }
    .nav__cta { width: 100%; margin-top: 0.4rem; }

    /* burger → X */
    .nav__toggle:checked ~ .nav__actions .nav__burger span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
    .nav__toggle:checked ~ .nav__actions .nav__burger span:nth-child(2) { opacity: 0; }
    .nav__toggle:checked ~ .nav__actions .nav__burger span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
  }

  @media (max-width: 500px) {
    .nav__inner { height: 64px; gap: 0.5rem; }
    .nav__word { font-size: 1.05rem; }
    .nav__mark { width: 34px; height: 34px; }
    .nav__circle { width: 40px; height: 40px; }
    .nav__actions { gap: 0.45rem; }
  }
</style>
