---
// Floating island nav, bluey.tv-style: logo left; UPPERCASE chunky navy links;
// a divider + circular mail button on the right (hamburger on mobile).
const links = [
  { label: 'Watch', href: '#watch' },
  { label: 'Learn', href: '#learn' },
  { label: 'Shop', href: '#shop' },
  { label: 'Story', href: '#story' },
  { label: 'Newsletter', href: '#newsletter' },
];
---

<header class="nav">
  <div class="wrap nav__inner">
    <a class="nav__brand" href="/">
      <img class="nav__mark" src="/characters/watermark.png" alt="" width="40" height="40" aria-hidden="true" />
      <span class="nav__word">Blu&nbsp;Baby&nbsp;Show</span>
    </a>

    <input type="checkbox" id="navtoggle" class="nav__toggle" aria-label="Toggle menu" />

    <nav class="nav__menu" aria-label="Primary">
      <div class="nav__links">
        {links.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </nav>

    <div class="nav__actions">
      <span class="nav__divider" aria-hidden="true"></span>
      <a class="nav__circle" href="#newsletter" aria-label="Get the newsletter">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
      <label class="nav__circle nav__burger" for="navtoggle" aria-label="Open menu">
        <span></span><span></span><span></span>
      </label>
    </div>
  </div>
</header>

<script is:inline>
  document.querySelectorAll('.nav__menu a').forEach((a) =>
    a.addEventListener('click', () => {
      const t = document.getElementById('navtoggle');
      if (t) t.checked = false;
    })
  );
</script>

<style>
  /* Floating "island" nav — a rounded bar detached from the edges */
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 0.8rem 16px 0;
    background: transparent;
  }
  .nav__inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    height: 68px;
    padding: 0 0.7rem 0 1.15rem;
    border-radius: 30px;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: saturate(180%) blur(14px);
    box-shadow: 0 14px 34px -14px rgba(43, 44, 65, 0.32), 0 2px 8px -2px rgba(43, 44, 65, 0.08);
    border: 1.5px solid rgba(255, 255, 255, 0.7);
  }

  /* ---- Brand ---- */
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--blu-deep);
    white-space: nowrap;
  }
  .nav__word { overflow: hidden; text-overflow: ellipsis; }
  .nav__mark {
    flex: none;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: block;
    filter: drop-shadow(0 4px 8px rgba(43, 44, 65, 0.22));
  }

  /* ---- Links (desktop): UPPERCASE chunky navy ---- */
  .nav__menu { display: flex; align-items: center; }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .nav__links a {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.96rem;
    text-transform: uppercase;
    letter-spacing: 0.045em;
    color: var(--blu-deep);
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav__links a:hover { background: var(--cream-2); color: var(--blu-d); }

  /* ---- Right cluster: divider + circular buttons ---- */
  .nav__actions { display: flex; align-items: center; gap: 0.7rem; }
  .nav__divider {
    width: 2px;
    height: 28px;
    border-radius: 2px;
    background: rgba(48, 89, 138, 0.2);
  }
  .nav__circle {
    flex: none;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--blu-deep);
    color: #fff;
    cursor: pointer;
    box-shadow: 0 6px 14px -6px rgba(43, 44, 65, 0.4);
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.15s ease;
  }
  .nav__circle:hover { transform: translateY(-2px); }
  /* toggle: visually hidden but KEYBOARD-focusable (not display:none) */
  .nav__toggle { position: absolute; width: 1px; height: 1px; opacity: 0; margin: 0; }
  .nav__toggle:focus-visible ~ .nav__actions .nav__burger { outline: 3px solid var(--blu-d); outline-offset: 3px; }
  .nav__burger { display: none; flex-direction: column; gap: 5px; }
  .nav__burger span {
    display: block;
    width: 20px;
    height: 2.5px;
    border-radius: 3px;
    background: #fff;
    transition: transform 0.22s ease, opacity 0.18s ease;
  }

  /* ---- Mobile ---- */
  @media (max-width: 860px) {
    .nav__divider { display: none; }
    .nav__burger { display: flex; }

    .nav__menu {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: #fff;
      padding: 0.9rem 1rem 1.1rem;
      border-radius: 26px;
      border: 1.5px solid rgba(255, 255, 255, 0.7);
      box-shadow: 0 24px 44px -18px rgba(43, 44, 65, 0.4);
      transform: translateY(-14px);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: transform 0.22s ease, opacity 0.22s ease, visibility 0s 0.22s;
    }
    .nav__toggle:checked ~ .nav__menu {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: transform 0.22s ease, opacity 0.22s ease, visibility 0s 0s;
    }
    .nav__links { flex-direction: column; align-items: stretch; gap: 0.1rem; }
    .nav__links a { font-size: 1.05rem; padding: 0.7rem 0.9rem; }

    .nav__toggle:checked ~ .nav__actions .nav__burger span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
    .nav__toggle:checked ~ .nav__actions .nav__burger span:nth-child(2) { opacity: 0; }
    .nav__toggle:checked ~ .nav__actions .nav__burger span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
  }

  @media (max-width: 500px) {
    .nav { padding: 0.6rem 12px 0; }
    .nav__inner { height: 62px; gap: 0.5rem; padding: 0 0.5rem 0 0.9rem; }
    .nav__word { font-size: 1.05rem; }
    .nav__mark { width: 36px; height: 36px; }
    .nav__circle { width: 44px; height: 44px; }
    .nav__actions { gap: 0.45rem; }
  }
</style>
